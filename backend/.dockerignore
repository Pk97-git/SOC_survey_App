# Ignore git files
.git
.gitignore

# Ignore node_modules (we want to npm install inside the container)
node_modules/

# Ignore local environment files
.env
.env.*

# Ignore build output (we will build inside the container)
dist/

# Ignore debug logs
npm-debug.log
npm-debug.log.*
yarn-debug.log
yarn-error.log

# Ignore OS files
.DS_Store
Thumbs.db
